# Copy this file to .env.development or .env.local and fill in your values.
# Variables prefixed with VITE_ are exposed to the browser bundle.

# Full base URL of the backend API (scheme + host + port + /api path)
# Examples:
#   Local dev:   http://localhost:5001/api
#   Docker dev:  http://localhost:8080/api
#   Production:  https://api.yourdomain.com/api
VITE_API_URL=http://localhost:5001/api

# Environment label
VITE_ENV=development
