# ──────────────────────────────────────────────────────────
# Production environment — set VITE_API_URL to the live API.
# These values are baked in at build time (npm run build).
# ──────────────────────────────────────────────────────────

# Full base URL of the backend API
VITE_API_URL=https://api.yourdomain.com/api

# Environment label
VITE_ENV=production
